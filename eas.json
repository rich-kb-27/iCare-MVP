{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "GRADLE_OPTS": "-Dorg.gradle.version=8.10.2"
      },
      "android": {
        "buildType": "apk",
        "googleServicesFile": "./google-services.json"
      }
    },

    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "GRADLE_OPTS": "-Dorg.gradle.version=8.10.2"
      },
      "android": {
        "buildType": "apk",
        "googleServicesFile": "./google-services.json"
      }
    },

    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.version=8.10.2"
      },
      "android": {
        "buildType": "apk",
        "googleServicesFile": "./google-services.json"
      }
    }
  }
}
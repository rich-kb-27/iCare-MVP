{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "KOTLIN_DAEMON_ARGS": "-Xskip-metadata-version-check"
      },
      "android": {
        "buildType": "apk"
      }
    },

    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "KOTLIN_DAEMON_ARGS": "-Xskip-metadata-version-check"
      },
      "android": {
        "buildType": "apk"
      }
    },

    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "KOTLIN_DAEMON_ARGS": "-Xskip-metadata-version-check"
      },
      "android": {
        "buildType": "apk"
      }
    }
  }
}